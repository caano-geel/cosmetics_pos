# Environment variables (Render / Docker)
# Copy to .env for local docker-compose testing only — never commit .env

APP_ENV=production

# MySQL (external database — Render has no free MySQL)
DB_HOST=your-mysql-host.example.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=cbpos_db

# Optional: force canonical URL (otherwise auto-detected)
# APP_URL=https://your-app.onrender.com
